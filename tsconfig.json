{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "test-prisma.js"],
  "exclude": [
    "node_modules", 
    "dist", 
    "**/*.spec.ts", 
    "**/*.test.ts",
    "prisma.config.ts" // <-- ADD THIS LINE
  ]
}